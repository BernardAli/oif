# Copy to .env and adjust. Without DATABASE_URL the app uses SQLite.

# --- Core ---
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# Comma-separated https origins for CSRF when deployed, e.g.
# CSRF_TRUSTED_ORIGINS=https://onesimusimpact.org,https://www.onesimusimpact.org

# --- Database (PostgreSQL in production) ---
# DATABASE_URL=postgres://user:password@localhost:5432/oif_db

# --- Payments (Paystack Ghana) ---
# PAYSTACK_SECRET_KEY=sk_test_xxx
# PAYSTACK_PUBLIC_KEY=pk_test_xxx
# Explicitly enable simulated successful payments in local/demo environments only.
PAYSTACK_DEMO_MODE=True
# Provider credentials can instead be managed by an authorized administrator in
# Site CMS > Integrations. Environment values remain the secure deployment fallback.

# --- Email / transactional notifications ---
# Leave the backend as console for local dev (messages print to the log).
# For production, switch to SMTP (Gmail, Brevo, Mailgun, SendGrid, SES, PythonAnywhere):
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.your-provider.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-username
# EMAIL_HOST_PASSWORD=your-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=Onesimus Impact Foundation <hello@onesimusimpact.org>
# OIF_NOTIFY_EMAIL=hello@onesimusimpact.org

# --- Production security (auto-enabled when DJANGO_DEBUG=False) ---
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
